# Скопируй в .env и заполни значения. НЕ загружай .env на GitHub!

# Токен бота (из @BotFather)
BOT_TOKEN=1234567890:ABCDefGhIJKlmNOpQRsTUVwxyZ

# URL фронтенда на Vercel
WEB_APP_URL=https://your-app.vercel.app

# Ваш Telegram ID (узнать у @userinfobot)
ADMIN_ID=123456789

# Порт API-сервера (Railway выставляет автоматически)
PORT=8080

# Курс конвертации рублей в Stars (1 Star ≈ 1.5 ₽)
STARS_RATE=1.5
